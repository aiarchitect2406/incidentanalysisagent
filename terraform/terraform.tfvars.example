# Copy to terraform.tfvars and fill in, or pass these as -var flags / via
# `make tf-apply`. See variables.tf for full descriptions.

project_id = "your-gcp-project-id"
region     = "us-central1"

# Leave empty (or omit) for an auto-generated random suffix — the right
# default for a workshop where engineers shouldn't have to coordinate names.
# Set to your name for a stable, human-readable suffix instead:
# lab_user_id = "alice"
lab_user_id = ""

# First engineer (or an admin) in a freshly-set-up project: leave this true.
# Every SUBSEQUENT engineer joining an ALREADY-set-up shared project should
# set this to false so their own `terraform destroy` can't remove shared
# project-level API enablement / IAM bindings someone else's lab still needs.
manage_shared_infra = true
